generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                  @id @default(uuid())
  email                String                  @unique
  phoneNumber          String                  @unique
  passwordHash         String
  fullName             String
  gender               String?
  address              String?
  role                 Role                    @default(CUSTOMER)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  pointsBalance        Int                     @default(0)
  referralCode         String                  @unique
  referredById         String?
  fcmToken             String?
  assignedAppointments Appointment[]           @relation("AppointmentStaff")
  appointments         Appointment[]
  auditLogs            AuditLog[]
  cartItems            CartItem[]
  favorites            Favorite[]
  measurementProfiles  MeasurementProfile[]
  notifications        NotificationRecipient[]
  orders               Order[]
  pointTransactions    PointTransaction[]
  assignedVisits       StoreVisit[]            @relation("StaffVisits")
  visitRequests        StoreVisit[]            @relation("CustomerVisits")
  supportTickets       SupportTicket[]
  referredBy           User?                   @relation("UserReferrals", fields: [referredById], references: [id])
  referrals            User[]                  @relation("UserReferrals")
  couponsUsed          UserCoupon[]
  visitReports         VisitReport[]           @relation("StaffReports")

  @@index([referredById])
  @@index([role])
  @@index([role, createdAt])
}

model MeasurementProfile {
  id            String               @id @default(uuid())
  userId        String
  profileName   String
  fullLength    Decimal?             @db.Decimal(5, 2)
  shoulderWidth Decimal?             @db.Decimal(5, 2)
  upperChest    Decimal?             @db.Decimal(5, 2)
  bust          Decimal?             @db.Decimal(5, 2)
  waist         Decimal?             @db.Decimal(5, 2)
  hip           Decimal?             @db.Decimal(5, 2)
  armLength     Decimal?             @db.Decimal(5, 2)
  sleeveLength  Decimal?             @db.Decimal(5, 2)
  neck          Decimal?             @db.Decimal(5, 2)
  seat          Decimal?             @db.Decimal(5, 2)
  skirtLength   Decimal?             @db.Decimal(5, 2)
  pantLength    Decimal?             @db.Decimal(5, 2)
  tailorNotes   String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  history       MeasurementHistory[]
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders        Order[]

  @@index([userId])
}

model MeasurementHistory {
  id             String             @id @default(uuid())
  profileId      String
  changedBy      String
  previousValues Json
  newValues      Json
  changedAt      DateTime           @default(now())
  profile        MeasurementProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model Category {
  id            String        @id @default(uuid())
  name          String        @unique
  slug          String        @unique
  imageUrl      String?
  order         Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  products      Product[]
  subCategories SubCategory[]
}

model SubCategory {
  id         String   @id @default(uuid())
  name       String
  slug       String
  imageUrl   String?
  order      Int      @default(0)
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products   Product[] @relation("ProductSubCategory")

  @@unique([categoryId, slug])
  @@index([categoryId])
}

model Product {
  id                  String       @id @default(uuid())
  name                String
  description         String
  price               Decimal      @db.Decimal(10, 2)
  materialInfo        String?
  images              String[]
  bannerImage         String?
  categoryId          String
  subCategoryId       String?
  isTrending          Boolean      @default(false)
  trendingScheduledAt DateTime?
  inventoryQty        Int          @default(0)
  stockStatus         StockStatus  @default(IN_STOCK)
  targetGender        TargetGender @default(UNISEX)
  salesCount          Int          @default(0)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  cartItems           CartItem[]
  favorites           Favorite[]
  orderItems          OrderItem[]
  category            Category     @relation(fields: [categoryId], references: [id])
  subCategory         SubCategory? @relation("ProductSubCategory", fields: [subCategoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([subCategoryId])
  @@index([price])
  @@index([isTrending])
  @@index([stockStatus])
  @@index([createdAt])
  @@index([targetGender])
  @@index([salesCount])
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Coupon {
  id              String       @id @default(uuid())
  code            String       @unique
  discountPercent Int          @default(0)
  discountFlat    Decimal      @default(0.00) @db.Decimal(10, 2)
  maxDiscount     Decimal?     @db.Decimal(10, 2)
  expiryDate      DateTime
  isActive        Boolean      @default(true)
  maxUses         Int          @default(100)
  usedCount       Int          @default(0)
  createdAt       DateTime     @default(now())
  redemptions     UserCoupon[]

  @@index([isActive])
  @@index([expiryDate])
}

model UserCoupon {
  id       String   @id @default(uuid())
  userId   String
  couponId String
  usedAt   DateTime @default(now())
  coupon   Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, couponId])
}

model Appointment {
  id              String            @id @default(uuid())
  userId          String?
  date            DateTime
  timeSlot        String
  productType     String
  type            AppointmentType
  status          AppointmentStatus @default(PENDING)
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  assignedStaffId String?
  assignedStaff   User?             @relation("AppointmentStaff", fields: [assignedStaffId], references: [id])
  user            User?             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([assignedStaffId])
  @@index([date])
  @@index([status])
  @@index([date, timeSlot])
}

model StoreVisit {
  id              String       @id @default(uuid())
  customerId      String
  assignedStaffId String?
  preferredDate   DateTime
  confirmedDate   DateTime?
  address         String
  requirements    String
  status          VisitStatus  @default(PENDING)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  assignedStaff   User?        @relation("StaffVisits", fields: [assignedStaffId], references: [id])
  customer        User         @relation("CustomerVisits", fields: [customerId], references: [id])
  report          VisitReport?

  @@index([customerId])
  @@index([assignedStaffId])
  @@index([preferredDate])
  @@index([status])
  @@index([status, customerId])
}

model VisitReport {
  id              String     @id @default(uuid())
  visitId         String     @unique
  staffId         String
  completionNotes String
  mediaUrls       String[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  staff           User       @relation("StaffReports", fields: [staffId], references: [id])
  visit           StoreVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([staffId])
}

model PointTransaction {
  id        String   @id @default(uuid())
  userId    String
  points    Int
  reason    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Order {
  id                     String            @id @default(uuid())
  userId                 String?
  status                 OrderStatus       @default(PENDING)
  totalAmount            Decimal           @db.Decimal(10, 2)
  taxAmount              Decimal           @db.Decimal(10, 2)
  discountAmount         Decimal           @default(0.00) @db.Decimal(10, 2)
  payableAmount          Decimal           @db.Decimal(10, 2)
  paymentMethod          String
  isOfflineSales         Boolean           @default(false)
  invoiceNumber          String            @unique
  idempotencyKey         String?           @unique
  paymentStatus          PaymentStatus     @default(PENDING)
  transactionId          String?           @unique
  paymentGateway         String?
  gatewayResponse        Json?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  isQuickOrder           Boolean           @default(false)
  quickOrderReason       String?
  quickOrderStatus       QuickOrderStatus?
  quickOrderExpectedDate DateTime?
  quickOrderProposedDate DateTime?
  adminProposalNote      String?           @db.Text
  userRejectionNote      String?           @db.Text
  invoice                Invoice?
  user                   User?             @relation(fields: [userId], references: [id])
  orderItems             OrderItem[]
  fabricType             String?
  customizations         String?
  tailorNotes            String?
  measurementProfileId   String?
  measurementProfile     MeasurementProfile? @relation(fields: [measurementProfileId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@index([isOfflineSales])
  @@index([isQuickOrder])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Invoice {
  id        String   @id @default(uuid())
  orderId   String   @unique
  pdfUrl    String
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id])
}

model Banner {
  id             String         @id @default(uuid())
  imageUrl       String
  title          String?
  targetUrl      String?
  location       BannerLocation @default(HOME_SLIDER)
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  isActive       Boolean        @default(true)
  clicks         Int            @default(0)
  createdAt      DateTime       @default(now())
  order          Int            @default(0)

  @@index([isActive])
  @@index([order])
}

model Notification {
  id            String                  @id @default(uuid())
  title         String
  body          String
  type          NotificationType
  isScheduled   Boolean                 @default(false)
  scheduledTime DateTime?
  createdAt     DateTime                @default(now())
  recipients    NotificationRecipient[]
}

model NotificationRecipient {
  id             String       @id @default(uuid())
  notificationId String
  userId         String
  isRead         Boolean      @default(false)
  readAt         DateTime?
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@index([userId])
  @@index([userId, isRead])
}

model SupportTicket {
  id          String                 @id @default(uuid())
  userId      String
  subject     String
  description String
  status      TicketStatus           @default(OPEN)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  imageUrl    String?
  user        User                   @relation(fields: [userId], references: [id])
  messages    SupportTicketMessage[]

  @@index([userId])
}

model SupportTicketMessage {
  id         String        @id @default(uuid())
  ticketId   String
  sender     String
  senderName String
  text       String
  sentAt     DateTime      @default(now())
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  details   Json
  ipAddress String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model SystemSettings {
  id                         String   @id @default("default")
  lowStockThreshold          Int      @default(10)
  businessHoursStart         String   @default("09:00")
  businessHoursEnd           String   @default("18:00")
  pointsEarnRate             Int      @default(10)
  pointsRedeemRate           Decimal  @default(0.10) @db.Decimal(5, 2)
  otpCooldownMinutes         Int      @default(15)
  maxOtpFailures             Int      @default(3)
  updatedAt                  DateTime @updatedAt
  businessHours              Json?
  bookingSlotDurationMinutes Int      @default(60)
  maxBookingsPerSlot         Int      @default(5)
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  eventType String
  productId String?
  userId    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([eventType])
  @@index([productId])
  @@index([eventType, createdAt])
  @@index([eventType, productId])
}

enum Role {
  CUSTOMER
  STAFF
  ADMIN
  SUPERADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  RESCHEDULED
}

enum AppointmentType {
  MEASUREMENT
  CONSULTATION
  PRODUCT_SELECTION
}

enum VisitStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum QuickOrderStatus {
  PENDING
  APPROVED
  REJECTED
  DATE_CHANGE_PROPOSED
  USER_REJECTED_PROPOSAL
  ADMIN_FINAL_APPROVAL_PENDING
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  OUT_FOR_DELIVERY
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum BannerLocation {
  HOME_SLIDER
  PROMOTIONAL_SECTION
  OFFER_SECTION
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum StockStatus {
  IN_STOCK
  OUT_OF_STOCK
  LOW_STOCK
}

enum NotificationType {
  APPOINTMENT_REMINDER
  PROMOTIONAL_BLAST
  ORDER_UPDATE
}

enum TargetGender {
  MEN
  WOMEN
  KIDS
  UNISEX
}

enum OfferType {
  PERCENTAGE
  FLAT
  FREE_SHIPPING
  NONE
}

model Offer {
  id                    String    @id @default(uuid())
  title                 String
  description           String?
  type                  OfferType
  discountValue         Decimal   @default(0) @db.Decimal(10, 2)
  isFreeShipping        Boolean   @default(false)
  minOrderAmount        Decimal   @default(0) @db.Decimal(10, 2)
  maxDiscount           Decimal?  @db.Decimal(10, 2)
  applicableProductIds  String[]
  applicableCategoryIds String[]
  startDate             DateTime
  endDate               DateTime
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([isActive])
  @@index([startDate, endDate])
}

model StoreLocation {
  id           String   @id @default(uuid())
  name         String
  address      String
  city         String
  state        String
  pincode      String
  country      String   @default("India")
  phone        String?
  email        String?
  latitude     Decimal  @db.Decimal(10, 7)
  longitude    Decimal  @db.Decimal(10, 7)
  openingHours String   @default("09:00")
  closingHours String   @default("21:00")
  isActive     Boolean  @default(true)
  description  String?
  imageUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
  @@index([city])
}

model PromoContent {
  id            String        @id @default(uuid())
  title         String
  description   String?
  videoUrl      String
  thumbnailUrl  String?
  linkType      PromoLinkType @default(NONE)
  productId     String?
  externalUrl   String?
  sortOrder     Int           @default(0)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([isActive])
}

enum PromoLinkType {
  PRODUCT
  EXTERNAL
  BOTH
  NONE
}
