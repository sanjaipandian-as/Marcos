{
  "name": "backend",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --watch src -e ts --exec ts-node src/index.ts",
    "test": "jest --config jest.config.ts --runInBand",
    "test:jobs": "jest --config jest.config.ts tests/jobs.test.ts --runInBand",
    "test:unit": "jest --config jest.config.ts --testPathPattern=unit --runInBand",
    "test:integration": "jest --config jest.config.ts --testPathPattern=integration --runInBand",
    "test:socket": "jest --config jest.config.ts tests/socket.test.ts --runInBand",
    "seed": "ts-node src/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
    "@prisma/client": "^5.22.0",
    "@socket.io/redis-adapter": "^8.2.1",
    "argon2": "^0.40.1",
    "bullmq": "^5.1.9",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "firebase-admin": "^13.10.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.10",
    "pdfkit": "^0.15.0",
    "redis": "^4.6.13",
    "socket.io": "^4.7.4",
    "twilio": "^6.0.2",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.24",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.13.4",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "ioredis-mock": "^8.9.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prisma": "^5.10.2",
    "socket.io-client": "^4.7.4",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
